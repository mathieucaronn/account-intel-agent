# Clé API Anthropic (https://console.anthropic.com/) — synthèse des fiches
ANTHROPIC_API_KEY=

# Clé API Tavily (https://tavily.com/) — recherche web et presse, plan gratuit disponible
TAVILY_API_KEY=

# Optionnel : modèle Claude à utiliser (défaut : claude-sonnet-5)
# ANTHROPIC_MODEL=claude-sonnet-5

# Optionnel : langue par défaut des fiches, "fr" ou "en" (défaut : fr)
# DEFAULT_LANG=fr

# Optionnel — EXTENSION NON CONFORME AUX CGU LINKEDIN, voir LINKEDIN_MCP.md.
# Commande pour lancer un serveur MCP tiers (ex. linkedin-mcpserver) déjà
# installé et configuré séparément, avec ses propres identifiants.
# LINKEDIN_MCP_COMMAND=node /chemin/vers/linkedin-mcpserver/build/index.js
