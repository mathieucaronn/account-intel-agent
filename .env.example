# Clé API Tavily (https://tavily.com/) — recherche de presse, plan gratuit disponible
TAVILY_API_KEY=

# Optionnel : langue affichée par défaut à l'ouverture, "fr" ou "en" (défaut :
# fr). Un bouton FR/EN sur la page permet de toute façon de basculer à tout
# moment ; les deux langues sont toujours générées.
# DEFAULT_LANG=fr

# Optionnel : chemin du fichier de clients suivis (défaut : clients.json)
# CLIENTS_PATH=clients.json

# Optionnel : active un résumé du jour croisant presse/communiqués/réseaux
# sociaux via Claude (console.anthropic.com), au lieu du résumé plus sommaire
# fourni par Tavily. Nécessite pip install -r requirements-ai.txt.
# ANTHROPIC_API_KEY=
